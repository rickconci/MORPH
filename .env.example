# MORPH paths: copy to .env and set to your machine paths.
# All paths in data/scdata_file_path.csv and data/perturb_embed_file_path.csv
# are relative to MORPH_DATA_ROOT unless absolute.

# Repo root (optional; auto-detected from morph/config.py location if unset)
MORPH_REPO_DIR=/path/to/MORPH

# Base directory for datasets (required for relative paths in data/*.csv)
# Example: parent of morph_depmap_prior/ and full_perturbseq_datasets/
MORPH_DATA_ROOT=path/to/datasets

# Base directory for checkpoints/results (optional; default: <repo>/result)
MORPH_RESULT_DIR=path/to/results
